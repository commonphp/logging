  "description": "Configurable PSR-3 logging setup and runtime logging integrations for PHP applications.",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Logging\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Logging\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/runtime": "^0.3.1",
    "psr/log": "^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}